        script. 
            document.addEventListener("DOMContentLoaded", () => {
                    const dynamicImage = document.getElementById("dynamicImage");
                    const contentContainer = document.getElementById("contentContainer");
                    const adjustImageHeight = () => {
                        const contentHeight = contentContainer.offsetHeight;
                        dynamicImage.style.height = `${contentHeight}px`;
                    };
                    adjustImageHeight();
                    window.addEventListener("resize", adjustImageHeight);
                    new MutationObserver(adjustImageHeight).observe(contentContainer, { childList: true, subtree: true });
                });
            document.addEventListener("DOMContentLoaded", function () {
                var counter1 = 1;
                setInterval(function () {
                    document.getElementById('R' + counter1).checked = true;
                    counter1++;
                    if (counter1 > 5) {
                        counter1 = 1;
                    }
                }, 3000);
            });
            var copy = document.querySelectorALl('.logos-slide').cloneNode(true);
            document.querySelector('.logos').appendChild(copy);
            var copy = document.querySelectorAll('.logos-slide1').cloneNode(true);
            document.querySelector('.logos1').appendChild(copy);
        script 
