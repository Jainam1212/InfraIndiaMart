        script.             
            document.addEventListener("DOMContentLoaded", () => {
                    const dynamicImage = document.getElementById("dynamicImage");
                    const contentContainer = document.getElementById("contentContainer");

                    // Function to adjust the image height
                    const adjustImageHeight = () => {
                        const contentHeight = contentContainer.offsetHeight;
                        dynamicImage.style.height = `${contentHeight}px`;
                    };

                    // Adjust the image height initially
                    adjustImageHeight();

                    // Adjust the image height whenever the window is resized
                    window.addEventListener("resize", adjustImageHeight);

                    // Adjust the image height whenever the content changes
                    new MutationObserver(adjustImageHeight).observe(contentContainer, { childList: true, subtree: true });
                });
            function toggle(){
                event.preventDefault();
                var blur = document.querySelector('.overall');
                blur.classList.toggle('activeblur');
                var visible = document.querySelector('.popup');
                var styleI = window.getComputedStyle(visible);
                if(styleI.display=='none'){
                    visible.style.display='block';
                }
                else{
                    visible.style.display='none';
                }
            }
        script                 
                include ../js/navbar2.js
                include ../js/scroll.js   
                include ../js/ham.js   
